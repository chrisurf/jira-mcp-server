# Required: Jira Cloud instance URL (e.g., https://your-domain.atlassian.net)
JIRA_INSTANCE_URL=

# Required: Jira API token (generate at https://id.atlassian.com/manage-profile/security/api-tokens)
JIRA_API_TOKEN=

# Required: Email address associated with the Jira API token
JIRA_USER_EMAIL=

# Optional: Path to the MCP server configuration file (JSON)
MCP_CONFIG_PATH=
